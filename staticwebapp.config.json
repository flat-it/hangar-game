{
  "$schema": "https://json.schemastore.org/staticwebapp.config.json",
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/api/*", "/*.{css,js,png,svg,ico,json}"]
  },
  "routes": [
    {
      "route": "/login",
      "rewrite": "/.auth/login/line"
    }
  ],
  "auth": {
    "identityProviders": {
      "customOpenIdConnectProviders": {
        "line": {
          "registration": {
            "clientIdSettingName": "LINE_CHANNEL_ID",
            "clientCredential": {
              "clientSecretSettingName": "LINE_CHANNEL_SECRET"
            },
            "openIdConnectConfiguration": {
              "wellKnownOpenIdConfiguration": "https://access.line.me/.well-known/openid-configuration"
            }
          },
          "login": {
            "nameClaimType": "name",
            "scopes": ["openid", "profile"]
          }
        }
      }
    }
  },
  "globalHeaders": {
    "Cache-Control": "no-cache",
    "X-Content-Type-Options": "nosniff"
  }
}